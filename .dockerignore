# Ignore node modules and build output
node_modules
.next
.turbo

# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Environment files (compose will load .env at runtime; don't bake it into image)
.env
.env.*
!.env.example

# OS / Editor files
.DS_Store
.idea
.vscode

# Git
.git
.gitignore

# Other
.vercel
coverage
dist
build
tmp
cache
