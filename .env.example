# Copy this file to `.env` and fill in values. docker-compose will load it.

# Application
NODE_ENV=production

# Auth for basic protection (see lib/auth.ts)
AUTH_USERNAME=admin
AUTH_PASSWORD=change-me

# MongoDB (used in lib/mongodb.ts)
MONGODB_URI=mongodb://user:pass@host:27017/email_automation?authSource=admin

# SMTP settings (used in lib/smtp.ts)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_REQUIRE_TLS=true
SMTP_USER=mailer@example.com
SMTP_PASS=your_smtp_password
SMTP_FROM=Email Bot <mailer@example.com>
SMTP_REJECT_UNAUTHORIZED=true
SMTP_SKIP_VERIFY=false

# SMTP timeouts (used in lib/config/timeouts.ts) — values in ms
SMTP_CONNECTION_TIMEOUT=30000
SMTP_SOCKET_TIMEOUT=30000
SMTP_GREETING_TIMEOUT=10000
SMTP_TEST_TIMEOUT=60000

# Google Gemini (used in lib/gemini.ts)
GEMINI_API_KEY=your_gemini_api_key
GEMINI_MODEL=gemini-1.5-flash

# Next.js public URLs (uncomment and adjust if needed)
# NEXT_PUBLIC_APP_URL=http://localhost:3000
